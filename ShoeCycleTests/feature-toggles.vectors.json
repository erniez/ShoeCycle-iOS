{
  "schemaVersion": 1,
  "contract": "ShoeCycle feature-toggle deterministic bucketing",
  "doc": "architecture/feature-toggles.md",
  "algorithm": {
    "hash": "SHA-256",
    "hashInputFormat": "${flagKey}:${bucketingId}",
    "inputEncoding": "UTF-8",
    "hashBytesTaken": 4,
    "byteOrder": "big-endian",
    "integerType": "uint32",
    "bucketFormula": "bucket = hashUint32 % 100",
    "bucketRange": "[0,100)",
    "inclusionRule": "inRollout = bucket < rolloutPercentage"
  },
